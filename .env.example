# Configuration TotalGreen ETL
# Copier ce fichier vers .env et remplir avec vos vraies clés

# API OpenWeather
OPENWEATHER_API_KEY=votre_clé_openweather

# API AQICN (Qualité de l'air)
AQICN_API_KEY=votre_clé_aqicn

# Supabase (Base de données)
SUPABASE_URL=https://votre-projet.supabase.co
SUPABASE_KEY=votre_clé_service

# Configuration (optionnel)
COLLECTION_INTERVAL=60
